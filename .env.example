# Navidrome config
NAVIDROME_URL=http://navidrome:4533
NAVIDROME_ADMIN_USERNAME=admin
NAVIDROME_ADMIN_PASSWORD=changeme
NAVIDROME_LASTFM_ENABLED=false
NAVIDROME_LASTFM_API_KEY=
NAVIDROME_LASTFM_SECRET=

# Streaming provider: qobuz | tidal | amazon
SQUIDWTF_SOURCE=amazon
SQUIDWTF_QUALITY=lossless
SQUIDWTF_COUNTRY=US

# Storage: permanent | cache
SQUIDSUB_STORAGE_MODE=permanent
SQUIDSUB_FOLDER_TEMPLATE={artist}/{album}/{track} - {title}

# Music volume path (default: named volume; set to a path for bind mount)
# MUSIC_PATH=/mnt/data/music

# Port (docker-compose host port)
SQUIDSUB_PORT=5274
